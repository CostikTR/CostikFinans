{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile && pnpm approve-builds",
  "outputDirectory": ".next",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs22.x"
    },
    "app/**/route.js": {
      "runtime": "nodejs22.x"
    }
  }
}
